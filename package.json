{
  "name": "codeceptjs-tests",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "test": "npx codeceptjs run --steps",
    "test:ui": "npx codeceptjs run --steps --grep '@ui'",
    "test:api": "npx codeceptjs run --steps --grep '@api'",
    "test:headless": "HEADLESS=true codeceptjs run --steps",
    "allure:generate": "allure generate output/allure-results -o output/allure-report --clean",
    "allure:open": "allure open output/allure-report",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@codeceptjs/allure-legacy": "^1.0.2",
    "@codeceptjs/configure": "^1.0.6",
    "@codeceptjs/ui": "^1.3.8",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.3",
    "allure-commandline": "^2.37.0",
    "codeceptjs": "^3.7.6",
    "eslint": "^10.0.2",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
